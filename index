<style>
/* iOS & Apple Sistem Stilleri */
:root {
  --bg:#f5f0e8; --bg2:#ede7da; --surface:#faf7f2; --card-bg:#ffffff;
  --border:#ddd6c8; --border2:#c9bfb0; --text:#2c2416; --text2:#6b5f4e; --text3:#9c8f7e;
  --accent:#b5451b; --accent2:#d4622d; --accent-bg:#fdf0eb;
  --blue:#007aff; --green:#34c759; --red:#ff3b30;
  --shadow:0 8px 24px rgba(44,36,22,0.1); 
  --bottom-bar-h: calc(64px + env(safe-area-inset-bottom));
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
body {
  background:var(--bg); color:var(--text);
  font-family:-apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  min-height:100vh; font-size:16px;
  -webkit-text-size-adjust:100%; overscroll-behavior-y: none;
}
.app{display:flex;flex-direction:column;height:100vh;overflow:hidden;}

/* Üst Bar */
.topbar{
  background:rgba(250, 247, 242, 0.85); backdrop-filter:blur(15px); -webkit-backdrop-filter:blur(15px);
  border-bottom:1px solid var(--border);
  padding:12px 16px 10px; padding-top:calc(12px + env(safe-area-inset-top));
  position:sticky; top:0; z-index:50; display:flex; align-items:center; gap:10px;
}
.topbar-back{
  display:none; background:none; border:none; font-size:28px; line-height: 1; 
  color:var(--accent); cursor:pointer; padding:0 8px 0 0; flex-shrink:0;
}
.topbar-title{font-family:'Lora',serif;font-size:20px;font-weight:700;}
.topbar-sub{font-size:12px;color:var(--text3);font-family:'DM Mono',monospace;}

/* Ana İçerik */
.main{flex:1;overflow-y:auto; -webkit-overflow-scrolling: touch; padding-bottom: calc(var(--bottom-bar-h) + 20px);}
.content{padding:16px 14px;}

/* Alt Navigasyon */
.bottom-nav{
  position:fixed; bottom:0; left:0; right:0; z-index:200;
  background:rgba(250, 247, 242, 0.9); backdrop-filter:blur(15px); -webkit-backdrop-filter:blur(15px);
  border-top:1px solid var(--border); display:flex; align-items:stretch;
  padding-bottom:env(safe-area-inset-bottom);
}
.bnav-item{
  flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center;
  gap:4px; padding:10px 4px; cursor:pointer; transition:all .2s ease; border:none; background:none;
}
.bnav-icon{font-size:22px; transition:transform 0.2s;}
.bnav-label{font-size:10px; font-weight:600; color:var(--text3);}
.bnav-item.active .bnav-label{color:var(--accent);}
.bnav-item.active .bnav-icon{transform:scale(1.15) translateY(-2px);}

/* Grid & Listeler (Konular) */
.topic-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.topic-card{background:var(--card-bg);border:1px solid var(--border);border-radius:16px;padding:20px 16px;box-shadow: 0 2px 8px rgba(0,0,0,0.04); text-align:center; cursor:pointer; transition: transform 0.1s;}
.topic-card:active{transform:scale(0.96); background:var(--bg2);}
.topic-icon{font-size:32px;margin-bottom:12px;}
.topic-name{font-family:'Lora',serif;font-size:15px;font-weight:600;margin-bottom:6px;}

/* 3D Flip Kart (Mobil Optimizasyonlu Sınav ve Çalışma Modu) */
.exam-container {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  height: 60vh; min-height: 400px; width: 100%; padding: 10px;
}
.flip-card-wrapper {
  perspective: 1200px; width: 100%; max-width: 380px; height: 100%; cursor: pointer;
}
.flip-card-inner {
  position: relative; width: 100%; height: 100%;
  transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  transform-style: preserve-3d; will-change: transform;
}
.flip-card-wrapper.flipped .flip-card-inner { transform: rotateY(180deg); }
.flip-face {
  position: absolute; width: 100%; height: 100%;
  backface-visibility: hidden; -webkit-backface-visibility: hidden;
  border-radius: 24px; padding: 24px 20px;
  box-shadow: var(--shadow); border: 1px solid var(--border);
  display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center;
  overflow-y: auto; -webkit-overflow-scrolling: touch;
}
.flip-front { background: var(--card-bg); }
.flip-back { background: #fff; transform: rotateY(180deg); }

.c-tag { position:absolute; top:20px; font-family:'DM Mono',monospace; font-size:11px; color:var(--text3); text-transform:uppercase; letter-spacing:1px; }
.c-q { font-family:'Lora',serif; font-size:22px; font-weight:700; color:var(--text); line-height:1.4; margin-top: 10px;}
.c-a { font-size:18px; color:var(--text); line-height:1.6; padding-bottom: 70px; margin-top: 10px; width: 100%;}
.c-a strong { color:var(--accent); font-weight:700; }
.c-hint { position:absolute; bottom:20px; font-size:12px; color:var(--text3); }

/* Butonlar & İlerleme */
.exam-actions {
  position: absolute; bottom: 20px; left: 0; right: 0;
  display: flex; justify-content: center; gap: 16px; width: 100%; padding: 0 20px;
}
.btn-exam {
  flex: 1; padding: 14px; border-radius: 16px; border: none; font-size: 16px; font-weight: 600; color: #fff;
  cursor: pointer; transition: transform 0.1s; -webkit-tap-highlight-color: transparent;
}
.btn-exam:active { transform: scale(0.95); }
.btn-correct { background: var(--green); }
.btn-wrong { background: var(--red); }
.btn-nav { background: var(--blue); }

.progress-bar { width:100%; height:8px; background:var(--border); border-radius:4px; margin-bottom: 20px; overflow:hidden; }
.progress-fill { height:100%; background:var(--accent); width:0%; transition: width 0.3s ease; }
.exam-status { font-family:'DM Mono',monospace; font-size:12px; color:var(--text3); margin-bottom:10px; text-align:center; }

/* Ekleme Formu Stilleri */
.form-card { background: var(--card-bg); border-radius: 16px; padding: 20px; border: 1px solid var(--border); box-shadow: var(--shadow); }
.form-label { display: block; font-size: 13px; font-weight: 600; color: var(--text2); margin-bottom: 8px; margin-top: 16px; }
.form-input { 
  width: 100%; padding: 14px; border-radius: 12px; border: 1px solid var(--border); 
  background: var(--bg); font-size: 16px; font-family: inherit; color: var(--text);
  -webkit-appearance: none; outline: none; transition: border-color 0.2s;
}
.form-input:focus { border-color: var(--accent); }
textarea.form-input { resize: vertical; min-height: 80px; }
</style>
</head>
