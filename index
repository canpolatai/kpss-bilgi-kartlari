    <span class="bnav-icon">📚</span><span class="bnav-label">Konular</span>
  </button>
  <button class="bnav-item" id="bn-sinav" onclick="showPage('sinav')">
    <span class="bnav-icon">🎯</span><span class="bnav-label">Sınav Modu</span>
  </button>
  <button class="bnav-item" id="bn-ekle" onclick="showPage('ekle')">
