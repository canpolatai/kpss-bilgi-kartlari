// Uygulama Değişkenleri
var CUSTOM_CARDS_KEY = "kpss_custom_cards";
var allCards = [];
var customCards = [];
var examQueue = [];
var wrongCards = [];
var currentExamCard = null;
var examTotalCount = 0;

var topicQueue = [];
var currentTopicIndex = 0;
var currentPage = "home";

// Başlangıç Yüklemesi
function loadCustomCards() {
  var stored = localStorage.getItem(CUSTOM_CARDS_KEY);
  if(stored) {
    try { customCards = JSON.parse(stored); } catch(e) {}
  }
  allCards = DEFAULT_CARDS.concat(customCards);
}

// ═══════════════════════════════
// SAYFA YÖNLENDİRME (ROUTER)
// ═══════════════════════════════
function showPage(page, topicId = null) {
  currentPage = page;
  document.querySelectorAll(".bnav-item").forEach(n => n.classList.remove("active"));
  var backBtn = document.getElementById("topbar-back");

  if (page === "home") {
    document.getElementById("bn-home").classList.add("active");
    document.getElementById("topbar-title").textContent = "Konular";
    document.getElementById("topbar-sub").textContent = "Çalışmak istediğin konuyu seç";
    backBtn.style.display = "none";
    renderHome();
  } else if (page === "sinav") {
    document.getElementById("bn-sinav").classList.add("active");
    document.getElementById("topbar-title").textContent = "Sınav Modu";
    document.getElementById("topbar-sub").textContent = "Rastgele 20 Kart";
    backBtn.style.display = "block";
    startExam();
  } else if (page === "ekle") {
    document.getElementById("bn-ekle").classList.add("active");
    document.getElementById("topbar-title").textContent = "Kart Ekle";
    document.getElementById("topbar-sub").textContent = "Kendi kartlarını oluştur";
    backBtn.style.display = "block";
    renderAddForm();
  } else if (page === "topic" && topicId) {
    document.getElementById("bn-home").classList.add("active");
    document.getElementById("topbar-title").textContent = TOPICS[topicId].label;
    document.getElementById("topbar-sub").textContent = "Konu Çalışması";
    backBtn.style.display = "block";
    startTopicStudy(topicId);
  }
}

// ═══════════════════════════════
// ANA SAYFA (KONU LİSTESİ)
// ═══════════════════════════════
function renderHome() {
  var ca = document.getElementById("content-area");
  var html = "<div class='topic-grid'>";
  Object.keys(TOPICS).forEach(t => {
    var count = allCards.filter(c => c.topic === t).length;
    html += `<div class='topic-card' onclick="showPage('topic', '${t}')">
      <div class='topic-icon'>${TOPICS[t].icon}</div>
      <div class='topic-name'>${TOPICS[t].label}</div>
      <div style="font-family:'DM Mono',monospace; font-size:12px; color:var(--text3);">${count} Kart</div>
    </div>`;
  });
  html += "</div>";
  ca.innerHTML = html;
}

// ═══════════════════════════════
// KONU ÇALIŞMA MODU
// ═══════════════════════════════
function startTopicStudy(topicId) {
  topicQueue = allCards.filter(c => c.topic === topicId);
  currentTopicIndex = 0;
  
  if (topicQueue.length === 0) {
    document.getElementById("content-area").innerHTML = `<div style='text-align:center;padding:50px;color:var(--text3)'>Bu konuya ait henüz kart bulunmuyor.</div>`;
    return;
  }
  renderTopicCard();
}

function renderTopicCard() {
  var ca = document.getElementById("content-area");
  var card = topicQueue[currentTopicIndex];
  var tagLabel = (TOPICS[card.topic] ? TOPICS[card.topic].label : "Genel").toUpperCase();
  var progressPct = ((currentTopicIndex + 1) / topicQueue.length) * 100;

  ca.innerHTML = `
    <div class="exam-status">Kart: ${currentTopicIndex + 1} / ${topicQueue.length}</div>
    <div class="progress-bar"><div class="progress-fill" style="width:${progressPct}%"></div></div>
    
    <div class="exam-container">
      <div class="flip-card-wrapper" id="topic-card" onclick="flipCard('topic-card')">
        <div class="flip-card-inner">
          <div class="flip-face flip-front">
            <div class="c-tag">${tagLabel}</div>
            <div class="c-q">${card.q}</div>
            <div class="c-hint">Cevabı görmek için karta dokun</div>
          </div>
          <div class="flip-face flip-back">
            <div class="c-tag">CEVAP</div>
            <div class="c-a">${card.a}</div>
            ${card.tip ? `<div style="margin-top:15px; font-size:14px; color:var(--accent); font-weight:600;">💡 ${card.tip}</div>` : ""}
          </div>
        </div>
      </div>
    </div>
    
    <div style="display:flex; justify-content:space-between; width:100%; max-width:380px; margin: 20px auto 0; gap:16px;">
        <button class="btn-exam" style="background:var(--border2); color:var(--text);" onclick="prevTopicCard()">Önceki</button>
        <button class="btn-exam btn-nav" onclick="nextTopicCard()">Sonraki</button>
    </div>
  `;
}

function nextTopicCard() {
  if (currentTopicIndex < topicQueue.length - 1) {
    currentTopicIndex++;
    renderTopicCard();
  } else {
    alert("Bu konudaki tüm kartları tamamladın! 🎉");
  }
}

function prevTopicCard() {
  if (currentTopicIndex > 0) {
    currentTopicIndex--;
    renderTopicCard();
  }
}

// ═══════════════════════════════
// SINAV MODU (20 RASTGELE KART)
// ═══════════════════════════════
function shuffleArray(array) {
  let curId = array.length;
  while (0 !== curId) {
    let randId = Math.floor(Math.random() * curId);
    curId -= 1;
    let tmp = array[curId];
    array[curId] = array[randId];
    array[randId] = tmp;
  }
  return array;
}

function startExam() {
  // Tamamen rastgele 20 kart seçimi
  var shuffled = shuffleArray([...allCards]);
  examQueue = shuffled.slice(0, 20);
  wrongCards = [];
  examTotalCount = examQueue.length;
  
  if (examTotalCount === 0) {
    document.getElementById("content-area").innerHTML = "<div style='text-align:center;padding:50px;'>Kart bulunamadı.</div>";
    return;
  }
  
  renderExamUI();
}

function renderExamUI() {
  var ca = document.getElementById("content-area");

  if (examQueue.length === 0) {
    if (wrongCards.length > 0) {
      examQueue = [...wrongCards];
      wrongCards = [];
      alert("Şimdi yanlış bildiğin kartları tekrar edeceğiz!");
    } else {
      ca.innerHTML = `
        <div style="text-align:center; padding-top:60px;">
          <div style="font-size:60px; margin-bottom:20px;">🏆</div>
          <h2 style="font-family:'Lora',serif; margin-bottom:10px;">Tebrikler!</h2>
          <p style="color:var(--text2); margin-bottom:30px;">Tüm kartları doğru bildin.</p>
          <button onclick="startExam()" style="padding:14px 24px; background:var(--accent); color:#fff; border:none; border-radius:12px; font-weight:600; font-size:16px;">Yeniden Başla</button>
        </div>
      `;
      return;
    }
  }

  currentExamCard = examQueue[0];
  var totalRemaining = examQueue.length + wrongCards.length;
  var progressPct = Math.round(((examTotalCount - totalRemaining) / examTotalCount) * 100);

  var tagLabel = (TOPICS[currentExamCard.topic] ? TOPICS[currentExamCard.topic].label : "Genel").toUpperCase();

  ca.innerHTML = `
    <div class="exam-status">Doğru Bilinen: ${examTotalCount - totalRemaining} / ${examTotalCount}</div>
    <div class="progress-bar"><div class="progress-fill" style="width:${progressPct}%"></div></div>
    
    <div class="exam-container">
      <div class="flip-card-wrapper" id="exam-card" onclick="flipCard('exam-card')">
        <div class="flip-card-inner">
          <div class="flip-face flip-front">
            <div class="c-tag">${tagLabel}</div>
            <div class="c-q">${currentExamCard.q}</div>
            <div class="c-hint">Cevabı görmek için karta dokun</div>
          </div>
          <div class="flip-face flip-back">
            <div class="c-tag">CEVAP</div>
            <div class="c-a">${currentExamCard.a}</div>
            ${currentExamCard.tip ? `<div style="margin-top:15px; font-size:14px; color:var(--accent); font-weight:600;">💡 ${currentExamCard.tip}</div>` : ""}
            <div class="exam-actions">
              <button class="btn-exam btn-wrong" onclick="answerExam(false, event)">❌ Yanlış</button>
              <button class="btn-exam btn-correct" onclick="answerExam(true, event)">✅ Doğru</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  `;
}

function answerExam(isCorrect, event) {
  event.stopPropagation(); 
  var answeredCard = examQueue.shift(); 
  if (!isCorrect) { wrongCards.push(answeredCard); }
  
  var cardEl = document.getElementById("exam-card");
  cardEl.style.transform = isCorrect ? "translateX(100vw) rotate(15deg)" : "translateX(-100vw) rotate(-15deg)";
  cardEl.style.opacity = "0";
  cardEl.style.transition = "all 0.4s ease";
  
  setTimeout(() => { renderExamUI(); }, 400);
}

function flipCard(id) {
  var card = document.getElementById(id);
  if (card) card.classList.toggle("flipped");
}

// ═══════════════════════════════
// KART EKLEME (YEREL DEPOLAMA)
// ═══════════════════════════════
function renderAddForm() {
  var ca = document.getElementById("content-area");
  var options = Object.keys(TOPICS).map(k => `<option value="${k}">${TOPICS[k].icon} ${TOPICS[k].label}</option>`).join('');
  
  ca.innerHTML = `
    <div class="form-card">
      <h3 style="margin-bottom:5px; font-family:'Lora',serif; font-size:18px;">Yeni Kart Oluştur</h3>
      <p style="font-size:12px; color:var(--text3); margin-bottom:15px;">Eklediğin kartlar cihazına kaydedilir ve Sınav/Konu modunda karşına çıkar.</p>
      
      <label class="form-label">Konu Seçimi</label>
      <select id="add-topic" class="form-input">${options}</select>

      <label class="form-label">Soru</label>
      <textarea id="add-q" class="form-input" placeholder="Soruyu buraya yazın..."></textarea>

      <label class="form-label">Cevap</label>
      <textarea id="add-a" class="form-input" placeholder="Cevabı buraya yazın... (Koyu yapmak için metni <strong> </strong> içine alabilirsiniz)"></textarea>

      <label class="form-label">İpucu (İsteğe Bağlı)</label>
      <input type="text" id="add-tip" class="form-input" placeholder="Akılda kalıcı bir not..." style="margin-bottom:24px;">

      <button onclick="saveNewCard()" style="width:100%; padding:14px; background:var(--accent); color:#fff; border:none; border-radius:12px; font-weight:600; font-size:16px; cursor:pointer;">Kartı Kaydet</button>
    </div>
  `;
}

function saveNewCard() {
  var topic = document.getElementById("add-topic").value;
  var q = document.getElementById("add-q").value.trim();
  var a = document.getElementById("add-a").value.trim();
  var tip = document.getElementById("add-tip").value.trim();
  
  if(!q || !a) {
    alert("Lütfen Soru ve Cevap alanlarını doldurun.");
    return;
  }
  
  var newCard = {
    id: "u_" + Date.now(),
    topic: topic,
    q: q,
    a: a,
    tip: tip
  };
  
  customCards.push(newCard);
  localStorage.setItem(CUSTOM_CARDS_KEY, JSON.stringify(customCards));
  allCards = DEFAULT_CARDS.concat(customCards);
  
  document.getElementById("add-q").value = '';
  document.getElementById("add-a").value = '';
  document.getElementById("add-tip").value = '';
  
  alert("Kart başarıyla kaydedildi! 🚀");
}

